# Copy to .env (chmod 600) on the Pi. Read by pi-dashboard.service.
# systemd parses this itself -- no quotes, no export, no shell expansion.

# Canvas LMS. Account > Settings > New Access Token.
CANVAS_TOKEN=
CANVAS_URL=https://csufullerton.instructure.com

# Listen address. Leave as 0.0.0.0 for LAN access.
# Set to 127.0.0.1 once the Cloudflare tunnel is up -- cloudflared connects to
# localhost, and closing off direct access is what makes trusting the Access
# header safe.
BIND=0.0.0.0

# Require Cloudflare Access identity for /api/* from non-local addresses.
# Turn on (=1) at the same time you set BIND=127.0.0.1.
REQUIRE_AUTH=0
